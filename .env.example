# Copy this file to .env, then paste your real Google AI Studio Gemini key.
# Real Gemini API keys usually start with AIza.

GEMINI_API_KEY=AIza_your_first_key_here

# Optional: add backup keys separated by commas.
# If one key is quota-limited, app.py tries the next key automatically.
GEMINI_API_KEYS=AIza_backup_key_1,AIza_backup_key_2

GEMINI_MODEL=gemini-2.5-flash
